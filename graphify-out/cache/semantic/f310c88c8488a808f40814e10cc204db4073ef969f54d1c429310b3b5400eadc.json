t": null, "author": null, "contributor": null}, {"id": "project_jarvis_acculynx_get_job_payments_overview", "label": "GET /jobs/{id}/payments-overview", "file_type": "concept", "source_file": "Project Jarvis/AccuLynx.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_jarvis_acculynx_get_job_sales_owner", "label": "GET /jobs/{id}/sales-owner", "file_type": "concept", "source_file": "Project Jarvis/AccuLynx.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_jarvis_acculynx_get_job_representatives", "label": "GET /jobs/{id}/representatives", "file_type": "concept", "source_file": "Project Jarvis/AccuLynx.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_jarvis_acculynx_get_users", "label": "GET /users", "file_type": "concept", "source_file": "Project Jarvis/AccuLynx.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_jarvis_acculynx_webhook_api", "label": "AccuLynx Webhook Subscription API", "file_type": "concept", "source_file": "Project Jarvis/AccuLynx.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_jarvis_acculynx_rate_limits", "label": "AccuLynx Rate Limits", "file_type": "rationale", "source_file": "Project Jarvis/AccuLynx.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "30 requests/sec per IP (HTTP 429 if exceeded), then 10 requests/sec per API key; higher limits require applying through the AccuLynx Partner Program."}, {"id": "project_jarvis_acculynx_zero_developer_support", "label": "Zero Developer Support Blocker", "file_type": "rationale", "source_file": "Project Jarvis/AccuLynx.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "AccuLynx explicitly states it does not support, coach, or explain its APIs the way it supports its main product \u2014 only a Contact Us form exists for troubleshooting; flagged as a real blocker to raise aggressively in planning."}, {"id": "project_jarvis_acculynx_per_location_keys", "label": "Per-Location API Keys Blocker", "file_type": "rationale", "source_file": "Project Jarvis/AccuLynx.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each company location requires its own API key, multiplying key-management overhead for a multi-location Shumaker footprint."}, {"id": "project_jarvis_acculynx_write_capable_keys", "label": "Write-Capable Keys Blocker", "file_type": "rationale", "source_file": "Project Jarvis/AccuLynx.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "AccuLynx API keys have no read-only scope and are write-capable ('can be used by anyone to expose or manipulate your company data'), so read-only access must be enforced entirely at the MCP tool layer by only implementing GET tools."}, {"id": "project_jarvis_acculynx_no_pagination_guidance", "label": "No Pagination/Back-pressure Guidance Blocker", "file_type": "rationale", "source_file": "Project Jarvis/AccuLynx.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "AccuLynx publishes no detailed pagination/back-pressure guidance beyond the rate limits; mitigation is exponential backoff with jitter."}, {"id": "project_jarvis_acculynx_credential_status", "label": "AccuLynx Credential Status (ACCULYNX_API_KEY)", "file_type": "concept", "source_file": "Project Jarvis/AccuLynx.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_jarvis_acculynx_mcp_t