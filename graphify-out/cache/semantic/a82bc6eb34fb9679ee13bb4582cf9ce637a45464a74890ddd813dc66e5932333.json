{"nodes": [{"id": "project_jarvis_tldr_and_key_findings", "label": "TL;DR and Key Findings", "file_type": "document", "source_file": "Project Jarvis/TLDR and Key Findings.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_jarvis_tldr_and_key_findings_acculynx_dealbreaker_false", "label": "AccuLynx 'Dealbreaker' Is False (Key Finding)", "file_type": "rationale", "source_file": "Project Jarvis/TLDR and Key Findings.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "AccuLynx publishes a documented public REST API v2 with Bearer API-key auth and read endpoints for everything the Sales sub-agent needs; real constraints are per-location keys, a 10 req/sec/key rate limit, and write-capable keys that must be locked down."}, {"id": "project_jarvis_tldr_and_key_findings_two_agent_split", "label": "2-Agent Split Recommendation", "file_type": "concept", "source_file": "Project Jarvis/TLDR and Key Findings.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_jarvis_tldr_and_key_findings_connector_feasibility", "label": "Key Finding: Connector Feasibility Better Than Assumed", "file_type": "concept", "source_file": "Project Jarvis/TLDR and Key Findings.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_jarvis_tldr_and_key_findings_heterogeneous_auth", "label": "Key Finding: Heterogeneous Auth Must Be Abstracted", "file_type": "rationale", "source_file": "Project Jarvis/TLDR and Key Findings.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "OAuth2 three-legged flows with 24-hour token rotation (Google Ads, GHL v2) alongside static Bearer/API-key auth (AccuLynx, CallRail) argue strongly for wrapping each platform in its own MCP server that owns credential lifecycle."}, {"id": "project_jarvis_tldr_and_key_findings_read_only_enforceable", "label": "Key Finding: Read-only Is Enforceable But Not Free", "file_type": "rationale", "source_file": "Project Jarvis/TLDR and Key Findings.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Several APIs issue write-capable keys by default with no read-only scope, so read-only must be enforced at the database role, tool-allowlist, and prompt-guardrail layers \u2014 defense in depth."}, {"id": "project_jarvis_tldr_and_key_findings_hub_and_spoke_native", "label": "Key Finding: Claude Agent SDK Natively Implements Hub-and-Spoke", "file_type": "concept", "source_file": "Project Jarvis/TLDR and Key Findings.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_jarvis_tldr_and_key_findings_voice_bolt_on", "label": "Key Finding: Voice Is a Bolt-on, Not a Foundation", "file_type": "concept", "source_file": "Project Jarvis/TLDR and Key Findings.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "project_jarvis_tldr_and_key_findings_acculynx_dealbreaker_false", "target": "project_jarvis_acculynx", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Project Jarvis/TLDR and Key Findings.md", "source_location": null, "weight": 1.0}, {"source": "project_jarvis_tldr_and_key_findings_two_agent_split", "target": "project_jarvis_layer_3_orchestrator_topology", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Project Jarvis/TLDR and Key Findings.md", "source_location": null, "weight": 1.0}, {"source": "project_jarvis_tldr_and_key_findings_connector_feasibility", "target": "project_jarvis_layer_4_connectors_overview", "relation": "references", "confidence": "EXTRACTED"